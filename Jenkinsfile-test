@Library('jenkins-shared-lib') _

pipeline {
    agent {
        kubernetes {
            label "podinfo-deploy-${BUILD_NUMBER}"

            yaml """
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins-agent

  containers:

    # tools container
    - name: tools
      image: alpine/k8s:1.33.11
      command: ["sh", "-c", "sleep 600"]
      tty: true

    # python container
    - name: python
      image: python:3.11-slim
      command: ["sh", "-c", "sleep 600"]
      tty: true

  nodeSelector:
    workload/node-group: jenkins-agents
"""
        }
    }

    parameters {
        string(
            name: 'ENV',
            defaultValue: 'dev',
            description: 'Deployment environment'
        )
    }

    stages {
        stage('Debug containers') {
            steps {
                container('tools') {
                    sh '''
                        echo "Running in tools container"
                        kubectl version --client || true
                        sleep 10
                    '''
                }

                container('python') {
                    sh '''
                        echo "Running in python container"
                        python --version
                        sleep 10
                    '''
                }
            }
        }

        stage('Main logic') {
            steps {
                container('tools') {
                    sh '''
                        echo "Deploying to environment: ${ENV}"
                        sleep 10
                    '''
                }
            }
        }
    }
}