@Library('jenkins-shared-lib') _

pipeline {
    agent {
        kubernetes {
            label "podinfo-deploy-${BUILD_NUMBER}"

            yaml """
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins-agent

  containers:

    - name: tools
      image: alpine/k8s:1.33.11
      command: ["sh", "-c", "sleep 600"]
      tty: true

    - name: python
      image: python:3.11-slim
      command: ["sh", "-c", "sleep 600"]
      tty: true

  nodeSelector:
    workload/node-group: jenkins-agents
"""
        }
    }

    parameters {
        string(
            name: 'NAME',
            defaultValue: 'DevOps Engineer',
            description: 'Name to greet'
        )
    }

    stages {

        stage('Init') {
            steps {
                container('tools') {
                    sh 'echo "Starting pipeline..."'
                }
            }
        }

        stage('Shared Library Step') {
            steps {
                script {
                    sayHello(params.NAME)
                }
            }
        }

        stage('Python Check') {
            steps {
                container('python') {
                    sh '''
                        echo "Checking Python environment"
                        python --version
                        sleep 5
                    '''
                }
            }
        }

        stage('Kubernetes Check') {
            steps {
                container('tools') {
                    sh '''
                        echo "Checking kubectl"
                        kubectl version --client || true
                        sleep 5
                    '''
                }
            }
        }
    }

    post {
        always {
            container('tools') {
                sh 'echo "Pipeline finished!"'
            }
        }
    }
}