// PR validation pipeline (GitHub Actions → Jenkins)
// Ephemeral testing environment per PR via GitOps side branch + ApplicationSet; tests; PR close and branch delete cleanup.
//
// Parameters are passed from .github/workflows/podinfo-pr-validation.yaml (buildWithParameters).

@Library('jenkins-shared-lib') _

pipeline {

    agent {
        kubernetes {
            label "pr-validation-${env.BUILD_NUMBER}"
            yaml """
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins-agent
  containers:

    - name: tools
      image: devuser103/devtools:1.0.0
      command: [cat]
      tty: true

    - name: python
      image: python:3.11-slim
      command: [cat]
      tty: true

  nodeSelector:
    workload/node-group: jenkins-agents
"""
        }
    }

    parameters {
        string(name: 'IMAGE_TAG', description: 'Docker image tag (e.g. abc1234-dev)')
        string(name: 'SHORT_SHA', description: '7-char git SHA (no -dev suffix)')
        string(name: 'PR_NUMBER', description: 'GitHub pull request number')
        string(name: 'IMAGE_REPOSITORY', description: 'Docker image repository', defaultValue: 'devuser103/podinfo')
        string(name: 'GITHUB_PR_URL', defaultValue: '', description: 'Link to the GitHub PR')
        string(name: 'GITHUB_ACTIONS_RUN_URL', defaultValue: '', description: 'GitHub Actions run that triggered this build')
    }

    environment {
        GITOPS_REPO            = 'https://github.com/dana951/gitops-manifests.git'
        GIT_CREDS_ID           = 'gitops-manifests-github-app'
        GITOPS_BRANCH          = "pr-${params.PR_NUMBER}-${params.SHORT_SHA}"
        NAMESPACE              = "pr-${params.PR_NUMBER}-${params.SHORT_SHA}"
        ARGOCD_APP_NAME        = "pr-${params.PR_NUMBER}-${params.SHORT_SHA}"
        ARGOCD_MAIN_APP_NAME   = 'main-app'
        APP_SVC_URL            = "http://pr-${params.PR_NUMBER}-${params.SHORT_SHA}.pr-${params.PR_NUMBER}-${params.SHORT_SHA}.svc.cluster.local"
        GITOPS_BRANCH_CREATED  = 'false'
        GITOPS_PR_NUMBER       = ''
        ARGOCD_SERVER          = 'argocd-server.argocd.svc.cluster.local'
        K8S_DEPLOYMENT_NAME    = 'podinfo'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '30'))
        timeout(time: 45, unit: 'MINUTES')
        // timestamps() # ToDo - install Timestamper Plugin
        //ansiColor('xterm') # ToDo - install AnsiColor Plugin
    }

    stages {

        stage('Validate parameters') {
            steps {
                script {
                    if (!params.IMAGE_TAG?.trim()) {
                        error('IMAGE_TAG is required')
                    }
                    if (!params.SHORT_SHA?.trim()) {
                        error('SHORT_SHA is required')
                    }
                    if (!params.PR_NUMBER?.trim()) {
                        error('PR_NUMBER is required')
                    }

                    currentBuild.displayName = "#${env.BUILD_NUMBER} | PR-${params.PR_NUMBER} | ${params.SHORT_SHA}"
                    currentBuild.description = """
                    PR: ${params.GITHUB_PR_URL ?: 'n/a'}
                    Actions: ${params.GITHUB_ACTIONS_RUN_URL ?: 'n/a'}
                    Image: ${params.IMAGE_REPOSITORY}:${params.IMAGE_TAG}
                    GitOps branch: ${env.GITOPS_BRANCH}
                    ArgoCD Application: ${env.ARGOCD_APP_NAME}
                    Namespace: ${env.NAMESPACE}
                    """.stripIndent().trim()

                    echo """
                    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                    PR VALIDATION (ephemeral GitOps / ArgoCD)
                    IMAGE_TAG:              ${params.IMAGE_TAG}
                    SHORT_SHA:              ${params.SHORT_SHA}
                    PR_NUMBER:              ${params.PR_NUMBER}
                    IMAGE_REPOSITORY:       ${params.IMAGE_REPOSITORY}
                    GITHUB_PR_URL:          ${params.GITHUB_PR_URL}
                    GITHUB_ACTIONS_RUN_URL: ${params.GITHUB_ACTIONS_RUN_URL}
                    GITOPS_BRANCH:          ${env.GITOPS_BRANCH}
                    ARGOCD_APP_NAME:        ${env.ARGOCD_APP_NAME}
                    APP_SVC_URL:            ${env.APP_SVC_URL}
                    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                    """
                }
            }
        }
        stage('Create and push GitOps branch') {
            steps {
                container('tools') {
                    withCredentials([
                        usernamePassword(
                            credentialsId: env.GIT_CREDS_ID,
                            usernameVariable: 'GH_USER',
                            passwordVariable: 'GH_TOKEN'
                        )
                    ]) {
                        script {
                            def repoPath = env.GITOPS_REPO.replace('https://', '')
                            def repoUrl = "https://${env.GH_USER}:${env.GH_TOKEN}@${repoPath}"
                            def envDir = "environments/podinfo/${env.GITOPS_BRANCH}"
                            def valuesYaml = """
                                env:
                                  APP_ENV: "qa"
                                image:
                                  tag: ${params.IMAGE_TAG}
                                ephemeral:
                                  enabled: true
                                  namespace: "${env.NAMESPACE}"
                            """.stripIndent().trim() + '\n'

                            dir('gitops-work') {
                                sh """
                                    set -eu
                                    git clone --depth 1 "${repoUrl}" .
                                    git remote set-url origin "${repoUrl}"

                                    git config user.email "jenkins@ci.local"
                                    git config user.name "Jenkins CI"
                                    git checkout -B ${env.GITOPS_BRANCH}
                                    mkdir -p "${envDir}"
                                """
                                writeFile(
                                    file: "${envDir}/values.yaml",
                                    text: valuesYaml
                                )
                                sh """
                                    set -eu
                                    git add "${envDir}/values.yaml"
                                    git commit -m "ci(jenkins-${env.BUILD_NUMBER}): \"${env.GITOPS_BRANCH}\" [skip ci]"
                                    git push origin ${env.GITOPS_BRANCH}
                                """
                                env.GITOPS_BRANCH_CREATED = 'true'
                            }
                        }
                    }
                }
            }
        }

        stage('Create PR GitOps branch to main') {
            steps {
                container('tools') {
                    script {
                        def prMessage = "ci(jenkins-${env.BUILD_NUMBER}): \"${env.GITOPS_BRANCH}\" [skip ci]"
                        def gitopsPrNumber = createPullRequest(
                            prMessage: prMessage,
                            githubRepo: env.GITOPS_REPO,
                            headBranch: env.GITOPS_BRANCH,
                            baseBranch: 'main',
                            credentialsId: env.GIT_CREDS_ID
                        )
                        if (gitopsPrNumber == null) {
                            error('Stopping pipeline: GitOps PR was not opened or could not be resolved; PR is required.')
                        }
                        env.GITOPS_PR_NUMBER = gitopsPrNumber.toString()
                    }
                }
            }
        }

        stage('Wait for GitOps Sync') {
            steps {
                container('tools') {
                    script {
                        waitForArgoCDSync(
                            parentAppName: env.ARGOCD_MAIN_APP_NAME,
                            appName: env.ARGOCD_APP_NAME,
                            argocdServer: env.ARGOCD_SERVER,
                            credentialsId: 'argocd-token'
                        )

                        verifyK8sDeploymentImageTag(
                            deploymentName: env.K8S_DEPLOYMENT_NAME,
                            namespace: env.NAMESPACE,
                            expectedImage: "${params.IMAGE_REPOSITORY}:${params.IMAGE_TAG}"
                        )
                    }
                }
            }
        }

        stage('Smoke tests') {
            steps {
                container('python') {
                    runTests(
                        environment:     'qa',
                        appUrl:            env.APP_SVC_URL,
                        expectedVersion:   params.SHORT_SHA,
                        markers:           'smoke'
                    )
                }
            }
        }

        stage('E2E tests') {
            steps {
                container('python') {
                    runTests(
                        environment:     'qa',
                        appUrl:            env.APP_SVC_URL,
                        expectedVersion:   params.SHORT_SHA,
                        markers:           'e2e'
                    )
                }
            }
        }
    }

    post {
        always {
            script {
                container('tools') {
                    script {
                        if (env.GITOPS_PR_NUMBER?.trim()) {
                            closePullRequest(
                                prNumber: env.GITOPS_PR_NUMBER,
                                githubRepo: env.GITOPS_REPO,
                                credentialsId: env.GIT_CREDS_ID
                            )
                        }
                        if (env.GITOPS_BRANCH_CREATED == 'true') {
                            gitDeleteBranch(
                                remoteUrl: env.GITOPS_REPO,
                                branch: env.GITOPS_BRANCH,
                                credentialsId: env.GIT_CREDS_ID
                            )
                        }
                    }
                }
            }
            cleanWs()
        }
    }
}
